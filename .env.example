SECRET_KEY=change-me-super-secret-with-at-least-32-chars
JWT_SECRET_KEY=change-me-jwt-secret-with-at-least-32-chars
DATABASE_URL=sqlite:////app/instance/chat.db
JWT_EXPIRES_DAYS=7
MAX_CONTENT_LENGTH=20971520
SOCKETIO_ASYNC_MODE=eventlet
CORS_ORIGINS=*
VAPID_CLAIMS_SUB=mailto:admin@example.com

# --- WebRTC admin config (simple mode, no JSON editing) ---
WEBRTC_RING_TIMEOUT_SEC=45
WEBRTC_ENABLE_PUBLIC_STUN_FALLBACK=1
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_TURN_URLS=
WEBRTC_TURN_USERNAME=
WEBRTC_TURN_CREDENTIAL=

# --- WebRTC advanced mode (optional JSON override, merged with simple mode) ---
# WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"webrtc","credential":"strong-password"}]
WEBRTC_ICE_SERVERS_JSON=

HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
