# --- Core app ---
SECRET_KEY=change-me-super-secret-with-at-least-32-chars
JWT_SECRET_KEY=change-me-jwt-secret-with-at-least-32-chars
DATABASE_URL=sqlite:////app/instance/chat.db
JWT_EXPIRES_DAYS=7
MAX_CONTENT_LENGTH=20971520
SOCKETIO_ASYNC_MODE=threading
SOCKETIO_FORCE_EVENTLET=0
CORS_ORIGINS=*
VAPID_CLAIMS_SUB=mailto:admin@example.com

# --- Public domain / TLS (Caddy) ---
APP_DOMAIN=chat.example.com
ACME_EMAIL=admin@example.com

# --- WebRTC (app-side ICE config) ---
WEBRTC_RING_TIMEOUT_SEC=45
WEBRTC_ENABLE_PUBLIC_STUN_FALLBACK=1
WEBRTC_STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_TURN_URLS=turn:${APP_DOMAIN}:3478?transport=udp,turn:${APP_DOMAIN}:3478?transport=tcp
WEBRTC_TURN_USERNAME=webrtc
WEBRTC_TURN_CREDENTIAL=change-me-turn-password

# --- TURN server (coturn container) ---
TURN_REALM=${APP_DOMAIN}
TURN_LISTEN_PORT=3478
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
# Set public IP manually when server is behind NAT, for example: 203.0.113.10
TURN_EXTERNAL_IP=
# Dynamic IP helper:
# 0 = off, 1 = auto detect through external HTTP services
TURN_DETECT_EXTERNAL_IP=0
TURN_VERBOSE=0

# --- Advanced override (optional) ---
# WEBRTC_ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:turn.example.com:3478","username":"webrtc","credential":"strong-password"}]
WEBRTC_ICE_SERVERS_JSON=

HOST=0.0.0.0
PORT=5000
FLASK_DEBUG=0
